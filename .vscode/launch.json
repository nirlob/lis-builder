{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: LIS Builder",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "pythonPath": "${workspaceFolder}/venv/bin/python3",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}
